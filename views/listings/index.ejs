<% layout("/layouts/boilerplate") %>

  <style>
    /* Hero Section */
    .hero-section {
      position: relative;
      height: 60vh;
      min-height: 500px;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 50%, #f093fb 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      margin: calc(var(--space-6) * -1) calc(var(--space-6) * -1) var(--space-12);
    }

    .hero-overlay {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: linear-gradient(180deg, rgba(0, 0, 0, 0.3) 0%, rgba(0, 0, 0, 0.1) 100%);
    }

    .hero-content {
      position: relative;
      z-index: 2;
      text-align: center;
      color: white;
      max-width: 800px;
      padding: 0 var(--space-6);
    }

    .hero-title {
      font-family: var(--font-display);
      font-size: var(--text-6xl);
      font-weight: var(--font-extrabold);
      margin-bottom: var(--space-4);
      text-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
      animation: fadeInUp 0.8s ease-out;
    }

    .hero-subtitle {
      font-size: var(--text-xl);
      margin-bottom: var(--space-8);
      text-shadow: 0 2px 10px rgba(0, 0, 0, 0.3);
      animation: fadeInUp 0.8s ease-out 0.2s both;
    }

    .hero-search {
      max-width: 600px;
      margin: 0 auto;
      animation: fadeInUp 0.8s ease-out 0.4s both;
    }

    .hero-search-box {
      position: relative;
      background: var(--neutral-50);
      border-radius: var(--radius-full);
      padding: var(--space-2);
      box-shadow: var(--shadow-2xl);
      display: flex;
      align-items: center;
      gap: var(--space-3);
    }

    .hero-search-form {
      width: 100%;
      display: flex;
      align-items: center;
      gap: var(--space-3);
      margin: 0;
    }

    .hero-search-box input {
      flex: 1;
      border: none;
      padding: var(--space-3) var(--space-4);
      font-size: var(--text-base);
      outline: none;
      background: transparent;
    }

    .hero-search-box button {
      background: var(--gradient-primary);
      color: white;
      border: none;
      border-radius: var(--radius-full);
      padding: var(--space-3) var(--space-8);
      font-weight: var(--font-semibold);
      cursor: pointer;
      transition: all var(--transition-base);
    }

    .hero-search-box button:hover {
      transform: scale(1.05);
      box-shadow: var(--shadow-lg);
    }

    /* Filters Section */
    .filters-container {
      margin-bottom: var(--space-12);
      position: relative;
    }

    .filters-scroll {
      display: flex;
      gap: var(--space-4);
      overflow-x: auto;
      scroll-behavior: smooth;
      padding: var(--space-4) 0;
      scrollbar-width: none;
    }

    .filters-scroll::-webkit-scrollbar {
      display: none;
    }

    .filter-chip {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: var(--space-2);
      padding: var(--space-3) var(--space-4);
      background: var(--neutral-50);
      border: 2px solid var(--neutral-200);
      border-radius: var(--radius-lg);
      cursor: pointer;
      transition: all var(--transition-base);
      white-space: nowrap;
      flex-shrink: 0;
      text-decoration: none;
      color: var(--neutral-600);
    }

    .filter-chip:hover {
      border-color: var(--primary-500);
      background: rgba(255, 56, 92, 0.05);
      transform: translateY(-2px);
      color: var(--primary-500);
    }

    .filter-chip.active {
      background: var(--primary-500);
      border-color: var(--primary-500);
      color: white;
    }

    .filter-chip i {
      font-size: var(--text-2xl);
    }

    .filter-chip p {
      margin: 0;
      font-size: var(--text-sm);
      font-weight: var(--font-medium);
    }

    .tax-toggle-modern {
      display: flex;
      align-items: center;
      gap: var(--space-3);
      padding: var(--space-3) var(--space-5);
      background: var(--neutral-50);
      border: 2px solid var(--neutral-200);
      border-radius: var(--radius-lg);
      margin-left: var(--space-4);
      flex-shrink: 0;
      cursor: pointer;
      transition: all var(--transition-base);
    }

    .tax-toggle-modern:hover {
      border-color: var(--neutral-300);
    }

    /* Toggle Switch */
    .toggle-switch {
      position: relative;
      width: 44px;
      height: 24px;
      background: var(--neutral-300);
      border-radius: var(--radius-full);
      cursor: pointer;
      transition: background var(--transition-base);
    }

    .toggle-switch.active {
      background: var(--primary-500);
    }

    .toggle-switch::after {
      content: '';
      position: absolute;
      top: 2px;
      left: 2px;
      width: 20px;
      height: 20px;
      background: white;
      border-radius: 50%;
      transition: transform var(--transition-base);
    }

    .toggle-switch.active::after {
      transform: translateX(20px);
    }

    /* Listings Grid */
    .listings-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: var(--space-8);
      margin-bottom: var(--space-12);
    }

    .listing-card-modern {
      background: var(--neutral-50);
      border-radius: var(--radius-xl);
      overflow: hidden;
      transition: all var(--transition-base);
      cursor: pointer;
      border: 1px solid var(--neutral-200);
      text-decoration: none;
      color: inherit;
      display: block;
    }

    .listing-card-modern:hover {
      transform: translateY(-8px);
      box-shadow: var(--shadow-hover);
      border-color: transparent;
    }

    .listing-image-container {
      position: relative;
      width: 100%;
      padding-top: 66.67%;
      /* 3:2 Aspect Ratio */
      overflow: hidden;
      background: var(--neutral-200);
    }

    .listing-image {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform var(--transition-slow);
    }

    .listing-card-modern:hover .listing-image {
      transform: scale(1.1);
    }

    .listing-image-overlay {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: linear-gradient(180deg, rgba(0, 0, 0, 0) 0%, rgba(0, 0, 0, 0.3) 100%);
      opacity: 0;
      transition: opacity var(--transition-base);
    }

    .listing-card-modern:hover .listing-image-overlay {
      opacity: 1;
    }

    .wishlist-btn {
      position: absolute;
      top: var(--space-3);
      right: var(--space-3);
      width: 36px;
      height: 36px;
      background: rgba(255, 255, 255, 0.9);
      backdrop-filter: blur(10px);
      border: none;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: all var(--transition-base);
      z-index: 2;
    }

    .wishlist-btn:hover {
      background: white;
      transform: scale(1.1);
    }

    .wishlist-btn i {
      color: var(--neutral-700);
      transition: all var(--transition-base);
    }

    .wishlist-btn:hover i {
      color: var(--primary-500);
    }

    .listing-details {
      padding: var(--space-4);
    }

    .listing-title {
      font-family: var(--font-display);
      font-size: var(--text-lg);
      font-weight: var(--font-bold);
      color: var(--neutral-800);
      margin: 0 0 var(--space-2);
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .listing-location {
      font-size: var(--text-sm);
      color: var(--neutral-500);
      margin-bottom: var(--space-3);
      display: flex;
      align-items: center;
      gap: var(--space-1);
    }

    .listing-price {
      font-size: var(--text-lg);
      font-weight: var(--font-bold);
      color: var(--neutral-800);
      margin: 0;
    }

    .listing-price span {
      font-size: var(--text-sm);
      font-weight: var(--font-normal);
      color: var(--neutral-600);
    }

    .tax-info-modern {
      display: none;
      font-size: var(--text-xs);
      color: var(--neutral-500);
      margin-top: var(--space-1);
    }

    .tax-info-modern.visible {
      display: block;
    }

    /* Responsive Design */
    @media (max-width: 768px) {
      .hero-section {
        height: 50vh;
        min-height: 400px;
      }

      .hero-title {
        font-size: var(--text-4xl);
      }

      .hero-subtitle {
        font-size: var(--text-lg);
      }

      .listings-grid {
        grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
        gap: var(--space-6);
      }
    }

    @media (max-width: 480px) {
      .hero-section {
        margin: calc(var(--space-4) * -1) calc(var(--space-4) * -1) var(--space-8);
      }

      .listings-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <body>
    <!-- Hero Section -->
    <div class="hero-section">
      <div class="hero-overlay"></div>
      <div class="hero-content">
        <h1 class="hero-title">Find Your Perfect Escape</h1>
        <p class="hero-subtitle">Discover unique places to stay around the world</p>
        <div class="hero-search">
          <div class="hero-search-box">
            <form action="/listings/search" method="GET" class="hero-search-form">
              <i class="fa-solid fa-magnifying-glass"
                style="color: var(--neutral-400); margin-left: var(--space-3);"></i>
              <input type="text" name="q" placeholder="Where do you want to go?" />
              <button type="submit">
                <i class="fa-solid fa-magnifying-glass"></i>
                Search
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>

    <!-- Filters Section -->
    <div class="filters-container">
      <div class="filters-scroll">
        <a href="/listings" class="filter-chip">
          <i class="fa-solid fa-fire"></i>
          <p>Trending</p>
        </a>
        <a href="/listings/search?q=Room" class="filter-chip">
          <i class="fa-solid fa-bed"></i>
          <p>Rooms</p>
        </a>
        <a href="/listings/search?q=City" class="filter-chip">
          <i class="fa-solid fa-mountain-city"></i>
          <p>Iconic Cities</p>
        </a>
        <a href="/listings/search?q=Mountain" class="filter-chip">
          <i class="fa-solid fa-mountain"></i>
          <p>Mountains</p>
        </a>
        <a href="/listings/search?q=Castle" class="filter-chip">
          <i class="fa-solid fa-chess-rook"></i>
          <p>Castles</p>
        </a>
        <a href="/listings/search?q=Pool" class="filter-chip">
          <i class="fa-solid fa-person-swimming"></i>
          <p>Amazing Pools</p>
        </a>
        <a href="/listings/search?q=Camping" class="filter-chip">
          <i class="fa-solid fa-campground"></i>
          <p>Camping</p>
        </a>
        <a href="/listings/search?q=Farm" class="filter-chip">
          <i class="fa-solid fa-cow"></i>
          <p>Farms</p>
        </a>
        <a href="/listings/search?q=Arctic" class="filter-chip">
          <i class="fa-solid fa-snowflake"></i>
          <p>Arctic</p>
        </a>
        <a href="/listings/search?q=Dome" class="filter-chip">
          <i class="fa-solid fa-landmark-dome"></i>
          <p>Domes</p>
        </a>
        <a href="/listings/search?q=Boat" class="filter-chip">
          <i class="fa-solid fa-ship"></i>
          <p>Boats</p>
        </a>
        <a href="/listings/search?q=Beach" class="filter-chip">
          <i class="fa-solid fa-umbrella-beach"></i>
          <p>Beach</p>
        </a>

        <div class="tax-toggle-modern reveal reveal-right" id="taxToggle">
          <div class="toggle-switch" id="toggleSwitch"></div>
          <label style="cursor: pointer; margin: 0; font-size: var(--text-sm); font-weight: var(--font-medium);">
            Display Total After Taxes
          </label>
        </div>
      </div>
    </div>

    <!-- Listings Grid -->
    <div class="listings-grid">
      <% if (alllistings.length===0) { %>
        <div style="grid-column: 1 / -1; text-align: center; padding: 4rem;">
          <i class="fa-solid fa-magnifying-glass"
            style="font-size: 3rem; color: var(--neutral-300); margin-bottom: 1rem;"></i>
          <h3>No listings found</h3>
          <p>Try adjusting your search or filters to find what you're looking for.</p>
          <a href="/listings" class="btn-modern btn-primary" style="margin-top: 1rem; text-decoration: none;">View All
            Listings</a>
        </div>
        <% } else { %>
          <% for (const listing of alllistings) { %>
            <a href="/listings/<%= listing._id %>" class="listing-card-modern reveal reveal-up">
              <div class="listing-image-container">
                <img src="<%= listing.images && listing.images.length > 0 ? listing.images[0].url : (listing.image && listing.image.url ? listing.image.url : '') %>" class="listing-image" alt="<%= listing.title %>" loading="lazy" />
                <div class="listing-image-overlay"></div>
                <button class="wishlist-btn" onclick="event.preventDefault(); event.stopPropagation();">
                  <i class="fa-regular fa-heart"></i>
                </button>
              </div>
              <div class="listing-details">
                <h3 class="listing-title">
                  <%= listing.title %>
                </h3>
                <p style="font-size: var(--text-sm); color: var(--neutral-500); margin-top: -6px; margin-bottom: var(--space-2);">
                  <%= listing.guests || 1 %> guests &middot; 
                  <%= listing.bedrooms || 1 %> bedroom &middot; 
                  <%= listing.bathrooms || 1 %> bath
                </p>
                <p class="listing-location">
                  <i class="fa-solid fa-location-dot"></i>
                  <%= listing.location %>
                </p>
                <p class="listing-price">
                  &#8377; <%= listing.price.toLocaleString("en-IN") %>
                    <span>/night</span>
                </p>
                <p class="tax-info-modern">
                  <i class="fa-solid fa-plus"></i> &#8377; <%= Math.round(listing.price * 0.18).toLocaleString("en-IN")
                    %>
                    taxes
                </p>
              </div>
            </a>
            <% } %>
              <% } %>
    </div>
  </body>

  <script>
    // Tax Toggle Functionality
    const taxToggle = document.getElementById('taxToggle');
    const toggleSwitch = document.getElementById('toggleSwitch');
    const taxInfoElements = document.querySelectorAll('.tax-info-modern');

    taxToggle.addEventListener('click', function () {
      toggleSwitch.classList.toggle('active');
      taxInfoElements.forEach(info => {
        info.classList.toggle('visible');
      });
    });

    // Filter Chips Interaction
    const filterChips = document.querySelectorAll('.filter-chip');
    // Highlight active chip based on URL
    const currentUrl = new URL(window.location.href);
    const searchParams = currentUrl.searchParams;
    const query = searchParams.get('q');

    if (query) {
      filterChips.forEach(chip => {
        if (chip.href.includes(`q=${query}`)) {
          chip.classList.add('active');
        }
      });
    } else {
      // If no query, highlight "Trending" (first one)
      if (currentUrl.pathname === '/listings') {
        filterChips[0].classList.add('active');
      }
    }

    // Wishlist Button Interaction
    const wishlistBtns = document.querySelectorAll('.wishlist-btn');
    wishlistBtns.forEach(btn => {
      btn.addEventListener('click', function (e) {
        e.preventDefault();
        e.stopPropagation();
        const icon = this.querySelector('i');
        if (icon.classList.contains('fa-regular')) {
          icon.classList.remove('fa-regular');
          icon.classList.add('fa-solid');
          icon.style.color = 'var(--primary-500)';
        } else {
          icon.classList.remove('fa-solid');
          icon.classList.add('fa-regular');
          icon.style.color = 'var(--neutral-700)';
        }
      });
    });
  </script>