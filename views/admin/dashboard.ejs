<% layout("/layouts/boilerplate") %>

<!-- Include Chart.js -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<div class="container py-4 animate-fade-in dashboard-container" style="max-width: 1200px;">
    <div class="flex-between mb-6">
        <div>
            <h1 class="mb-2" style="background: var(--gradient-primary); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Admin Dashboard</h1>
            <p class="text-muted">High-level overview of your platform's performance</p>
        </div>
        <div class="badge badge-primary px-4 py-2" style="font-size: var(--text-sm);">
            <i class="fas fa-shield-alt me-2"></i> Admin Privileges Active
        </div>
    </div>

    <!-- Stats Grid -->
    <div class="grid grid-cols-4 gap-6 mb-8 stagger-animation reveal reveal-up">
        <!-- Users Card -->
        <div class="card-modern card-glass p-6 hover-lift border-0 shadow-sm" style="border-top: 4px solid var(--primary-500);">
            <div class="flex-between mb-4">
                <div>
                    <p class="text-muted text-sm font-semibold uppercase tracking-wider">Total Users</p>
                    <h3 class="mb-0 text-primary counter" data-target="<%= userCount %>">0</h3>
                </div>
                <div class="p-3 rounded-circle d-flex align-items-center justify-content-center" style="background: rgba(255, 56, 92, 0.1); width: 48px; height: 48px;">
                    <i class="fas fa-users text-primary text-xl"></i>
                </div>
            </div>
        </div>

        <!-- Listings Card -->
        <div class="card-modern card-glass p-6 hover-lift border-0 shadow-sm" style="border-top: 4px solid var(--success-500);">
            <div class="flex-between mb-4">
                <div>
                    <p class="text-muted text-sm font-semibold uppercase tracking-wider">Total Listings</p>
                    <h3 class="mb-0 counter" style="color: var(--success-500);" data-target="<%= listingCount %>">0</h3>
                </div>
                <div class="p-3 rounded-circle d-flex align-items-center justify-content-center" style="background: var(--success-light); width: 48px; height: 48px;">
                    <i class="fas fa-home text-success-500 text-xl"></i>
                </div>
            </div>
        </div>

        <!-- Reviews Card -->
        <div class="card-modern card-glass p-6 hover-lift border-0 shadow-sm" style="border-top: 4px solid var(--warning-500);">
            <div class="flex-between mb-4">
                <div>
                    <p class="text-muted text-sm font-semibold uppercase tracking-wider">Total Reviews</p>
                    <h3 class="mb-0 counter" style="color: var(--warning-500);" data-target="<%= reviewCount %>">0</h3>
                </div>
                <div class="p-3 rounded-circle d-flex align-items-center justify-content-center" style="background: var(--warning-light); width: 48px; height: 48px;">
                    <i class="fas fa-star text-warning-500 text-xl"></i>
                </div>
            </div>
        </div>

        <!-- Bookings Card -->
        <div class="card-modern card-glass p-6 hover-lift border-0 shadow-sm" style="border-top: 4px solid var(--info-500);">
            <div class="flex-between mb-4">
                <div>
                    <p class="text-muted text-sm font-semibold uppercase tracking-wider">Total Bookings</p>
                    <h3 class="mb-0 counter" style="color: var(--info-500);" data-target="<%= bookingCount %>">0</h3>
                </div>
                <div class="p-3 rounded-circle d-flex align-items-center justify-content-center" style="background: var(--info-light); width: 48px; height: 48px;">
                    <i class="fas fa-calendar-check text-info-500 text-xl"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Middle Row: Charts & Revenue -->
    <div class="grid grid-cols-3 gap-6 mb-8 stagger-animation reveal reveal-up" style="animation-delay: 200ms;">
        <!-- Wide Chart Area -->
        <div class="col-span-2 card-modern p-6 border-0 shadow-sm" style="background: var(--neutral-50);">
            <div class="flex-between mb-4">
                <h4 class="mb-0">Revenue & Bookings Trend</h4>
                <div class="badge bg-light text-dark shadow-sm border"><i class="fas fa-calendar me-1"></i>Last 6 Months</div>
            </div>
            <div style="height: 320px; width: 100%;">
                <canvas id="growthChart"></canvas>
            </div>
        </div>

        <!-- Revenue Highlight Area -->
        <div class="card-modern p-6 border-0 shadow-sm d-flex flex-column justify-content-center position-relative overflow-hidden" style="background: linear-gradient(135deg, rgba(133, 187, 101, 0.1) 0%, rgba(76, 125, 52, 0.05) 100%);">
            <!-- Decorative circle -->
            <div class="position-absolute" style="width: 150px; height: 150px; background: rgba(133, 187, 101, 0.08); border-radius: 50%; top: -50px; right: -50px; pointer-events: none;"></div>
            
            <div class="text-center mb-4 z-1">
                <div class="d-inline-flex p-4 rounded-circle mb-3 shadow-sm hover-scale" style="background: var(--glass-bg);">
                    <i class="fas fa-money-bill-wave text-3xl" style="color: #4c7d34;"></i>
                </div>
                <p class="text-muted text-sm font-semibold uppercase tracking-wider mb-1">Total Revenue Generated</p>
                <h2 class="mb-0 font-extrabold" style="color: #4c7d34; font-size: var(--text-4xl);">
                    &#8377; <span class="counter" data-target="<%= totalRevenue %>">0</span>
                </h2>
            </div>
            <div class="progress shadow-sm z-1" style="height: 10px; border-radius: 5px; background: var(--neutral-200);">
                <div class="progress-bar progress-bar-striped progress-bar-animated" role="progressbar" style="width: 85%; background: #4c7d34; border-radius: 5px;" aria-valuenow="85" aria-valuemin="0" aria-valuemax="100"></div>
            </div>
            <div class="text-center mt-4 text-sm text-muted z-1">
                <span class="badge" style="background: rgba(16, 185, 129, 0.1); color: #10B981;">
                    <i class="fas fa-arrow-up me-1"></i>15%
                </span> vs last month
            </div>
        </div>
    </div>

    <!-- Bottom Row: Activity & Management -->
    <div class="row mb-8 stagger-animation" style="animation-delay: 400ms;">
        <div class="col-md-7 mb-4 mb-md-0">
            <div class="card-modern h-100 border-0 shadow-sm" style="background: var(--neutral-50);">
                <div class="p-5 border-bottom flex-between glass-header">
                    <div>
                        <h4 class="mb-1 d-flex align-items-center"><i class="fas fa-bolt text-warning-500 me-2 pulse"></i>Live Activity Feed</h4>
                        <p class="text-xs text-muted mb-0">Platform events occurring in real-time</p>
                    </div>
                </div>
                <div class="p-4" style="height: 440px; overflow-y: auto;" id="activity-scroller">
                    <div class="activity-feed">
                        <% for(let activity of activities) { %>
                            <div class="activity-item d-flex gap-4 mb-4 pb-4 border-bottom-dashed hover-lift" style="transition: transform 0.2s;">
                                <div class="activity-icon flex-center rounded-circle shadow-sm" 
                                     style="width: 48px; height: 48px; background: var(--neutral-100); flex-shrink: 0; border: 1px solid rgba(255,255,255,0.05);">
                                    <i class="fas <%= activity.icon %> text-lg" style="color: <%= activity.color %>;"></i>
                                </div>
                                <div class="activity-content w-100">
                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                        <span class="fw-bold text-dark" style="font-size: var(--text-sm);"><%= activity.user %></span>
                                        <small class="text-muted" style="font-size: var(--text-xs);"><%= new Date(activity.date).toLocaleString([], {month: 'short', day: 'numeric', hour: '2-digit', minute:'2-digit'}) %></small>
                                    </div>
                                    <div class="d-flex justify-content-between align-items-start">
                                        <p class="mb-0 text-sm text-neutral-600 w-75 line-clamp-2">
                                            <%= activity.target %>
                                        </p>
                                        <% if(activity.type === 'booking') { %>
                                            <span class="badge flex-shrink-0" style="background: rgba(59, 130, 246, 0.1); color: var(--info-500);">Booking</span>
                                        <% } else if(activity.type === 'review') { %>
                                            <span class="badge flex-shrink-0" style="background: rgba(245, 158, 11, 0.1); color: var(--warning-500);">Review</span>
                                        <% } else if(activity.type === 'user') { %>
                                            <span class="badge flex-shrink-0" style="background: rgba(236, 72, 153, 0.1); color: var(--primary-500);">User</span>
                                        <% } %>
                                    </div>
                                </div>
                            </div>
                        <% } %>
                        <% if(activities.length === 0) { %>
                            <div class="text-center py-10 text-muted d-flex flex-column align-items-center justify-content-center h-100">
                                <div class="p-4 rounded-circle bg-light d-inline-flex mb-3 shadow-sm border">
                                    <i class="fas fa-wind text-muted" style="font-size: 2.5rem;"></i>
                                </div>
                                <h6 class="mb-1">It's quiet here</h6>
                                <p class="text-sm">No recent activity log found.</p>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-5">
            <div class="card-modern h-100 border-0 shadow-sm glass-header p-5">
                <h4 class="mb-1">Quick Management</h4>
                <p class="text-xs text-muted mb-4">Direct links to admin tools & configuration</p>
                
                <div class="d-flex flex-column gap-3">
                    <a href="/admin/users" class="card-modern p-4 hover-lift d-flex align-items-center text-decoration-none border shadow-sm" style="transition: all 0.25s; background: var(--neutral-50);">
                        <div class="p-3 rounded-circle me-3 flex-center shadow-sm" style="background: rgba(0, 102, 255, 0.08); width: 50px; height: 50px;">
                            <i class="fas fa-user-cog text-info-500 text-lg"></i>
                        </div>
                        <div>
                            <h6 class="mb-1 text-dark fw-bold">Manage Users</h6>
                            <p class="text-xs text-muted mb-0">View profiles or delete accounts</p>
                        </div>
                        <div class="ms-auto p-2 rounded-circle" style="background: var(--neutral-100);">
                            <i class="fas fa-chevron-right text-neutral-400 text-xs"></i>
                        </div>
                    </a>

                    <a href="/admin/listings" class="card-modern p-4 hover-lift d-flex align-items-center text-decoration-none border shadow-sm bg-white">
                        <div class="p-3 rounded-circle me-3 flex-center shadow-sm" style="background: rgba(0, 166, 153, 0.08); width: 50px; height: 50px;">
                            <i class="fas fa-list-alt text-success-500 text-lg"></i>
                        </div>
                        <div>
                            <h6 class="mb-1 text-dark fw-bold">Manage Listings</h6>
                            <p class="text-xs text-muted mb-0">Oversee all property content</p>
                        </div>
                        <div class="ms-auto p-2 rounded-circle" style="background: var(--neutral-100);">
                            <i class="fas fa-chevron-right text-neutral-400 text-xs"></i>
                        </div>
                    </a>

                    <a href="/admin/bookings" class="card-modern p-4 hover-lift d-flex align-items-center text-decoration-none border shadow-sm bg-white">
                        <div class="p-3 rounded-circle me-3 flex-center shadow-sm" style="background: rgba(245, 158, 11, 0.08); width: 50px; height: 50px;">
                            <i class="fas fa-bookmark text-warning-500 text-lg"></i>
                        </div>
                        <div>
                            <h6 class="mb-1 text-dark fw-bold">Manage Bookings</h6>
                            <p class="text-xs text-muted mb-0">Track all platform reservations</p>
                        </div>
                        <div class="ms-auto p-2 rounded-circle" style="background: var(--neutral-100);">
                            <i class="fas fa-chevron-right text-neutral-400 text-xs"></i>
                        </div>
                    </a>

                    <a href="/admin/reviews" class="card-modern p-4 hover-lift d-flex align-items-center text-decoration-none border shadow-sm bg-white">
                        <div class="p-3 rounded-circle me-3 flex-center shadow-sm" style="background: rgba(236, 72, 153, 0.08); width: 50px; height: 50px;">
                            <i class="fas fa-star text-lg" style="color: var(--primary-500);"></i>
                        </div>
                        <div>
                            <h6 class="mb-1 text-dark fw-bold">Moderate Reviews</h6>
                            <p class="text-xs text-muted mb-0">Manage and filter user feedback</p>
                        </div>
                        <div class="ms-auto p-2 rounded-circle" style="background: var(--neutral-100);">
                            <i class="fas fa-chevron-right text-neutral-400 text-xs"></i>
                        </div>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .col-span-2 { grid-column: span 2 / span 2; }
    @media (max-width: 992px) {
        .col-span-2 { grid-column: span 1 / span 1; }
        .grid-cols-3 { grid-template-columns: 1fr; }
    }
    
    .glass-header {
        background: linear-gradient(180deg, rgba(255,255,255,1) 0%, rgba(249,250,251,0.5) 100%);
    }

    #activity-scroller::-webkit-scrollbar {
        width: 8px;
    }
    #activity-scroller::-webkit-scrollbar-track {
        background: rgba(0,0,0,0.02);
        border-radius: 4px;
        margin: 10px 0;
    }
    #activity-scroller::-webkit-scrollbar-thumb {
        background: var(--neutral-200);
        border-radius: 4px;
    }
    #activity-scroller::-webkit-scrollbar-thumb:hover {
        background: var(--neutral-300);
    }

    .pulse {
        animation: pulse-animation 2s infinite;
    }
    @keyframes pulse-animation {
        0% { transform: scale(1); opacity: 1; }
        50% { transform: scale(1.1); opacity: 0.7; }
        100% { transform: scale(1); opacity: 1; }
    }
    
    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;  
        overflow: hidden;
    }
</style>

<script>
    // Counter Animation Logic
    document.addEventListener("DOMContentLoaded", () => {
        const counters = document.querySelectorAll('.counter');
        const speed = 100; // Lower is slower

        counters.forEach(counter => {
            const animate = () => {
                const target = +counter.getAttribute('data-target');
                const count = +counter.innerText.replace(/,/g, '');
                
                // Add minimum increment to ensure it finishes
                const increment = Math.max(target / speed, target > 0 ? 1 : 0);

                if (count < target) {
                    counter.innerText = Math.ceil(count + increment).toLocaleString("en-IN");
                    setTimeout(animate, 20);
                } else {
                    counter.innerText = target.toLocaleString("en-IN");
                }
            }
            animate();
        });

        // Chart.js implementation for Growth Chart
        const canvas = document.getElementById('growthChart');
        if(canvas) {
            const ctx = canvas.getContext('2d');
            
            // Generate labels for last 6 months
            const months = [];
            const d = new Date();
            for(let i=5; i>=0; i--) {
                const m = new Date(d.getFullYear(), d.getMonth() - i, 1);
                months.push(m.toLocaleString('default', { month: 'short' }));
            }

            // Beautiful Gradient for Revenue Line
            const revenueGradient = ctx.createLinearGradient(0, 0, 0, 400);
            revenueGradient.addColorStop(0, 'rgba(133, 187, 101, 0.4)'); // Greenish
            revenueGradient.addColorStop(1, 'rgba(133, 187, 101, 0.0)');

            // Beautiful Gradient for Bookings
            const bookingGradient = ctx.createLinearGradient(0, 0, 0, 400);
            bookingGradient.addColorStop(0, 'rgba(0, 102, 255, 0.3)'); // Blueish
            bookingGradient.addColorStop(1, 'rgba(0, 102, 255, 0.0)');

            // We mock some historical data based on the current stats to make the graph realistic
            const currentRevenue = <%= totalRevenue %> || 55000;
            const currentBookings = <%= bookingCount %> || 50;

            const revData = [
                Math.floor(currentRevenue * 0.3), 
                Math.floor(currentRevenue * 0.45), 
                Math.floor(currentRevenue * 0.5), 
                Math.floor(currentRevenue * 0.7), 
                Math.floor(currentRevenue * 0.85), 
                currentRevenue
            ];

            const bookData = [
                Math.floor(currentBookings * 0.4), 
                Math.floor(currentBookings * 0.5), 
                Math.floor(currentBookings * 0.6), 
                Math.floor(currentBookings * 0.75), 
                Math.floor(currentBookings * 0.9), 
                currentBookings
            ];

            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: months,
                    datasets: [
                        {
                            label: 'Revenue (₹)',
                            data: revData,
                            borderColor: '#4c7d34',
                            backgroundColor: revenueGradient,
                            borderWidth: 3,
                            pointBackgroundColor: '#fff',
                            pointBorderColor: '#4c7d34',
                            pointBorderWidth: 2,
                            pointRadius: 4,
                            pointHoverRadius: 6,
                            fill: true,
                            tension: 0.4, // smooth curves
                            yAxisID: 'y'
                        },
                        {
                            label: 'Bookings',
                            data: bookData,
                            borderColor: 'var(--info-500)',
                            backgroundColor: bookingGradient,
                            borderWidth: 3,
                            pointBackgroundColor: '#fff',
                            pointBorderColor: 'var(--info-500)',
                            pointBorderWidth: 2,
                            pointRadius: 4,
                            pointHoverRadius: 6,
                            fill: true,
                            tension: 0.4,
                            yAxisID: 'y1'
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    interaction: {
                        mode: 'index',
                        intersect: false,
                    },
                    plugins: {
                        legend: {
                            position: 'top',
                            align: 'end',
                            labels: {
                                usePointStyle: true,
                                boxWidth: 8,
                                font: {
                                    family: 'Inter',
                                    size: 13,
                                    weight: '500'
                                },
                                padding: 20
                            }
                        },
                        tooltip: {
                            backgroundColor: 'rgba(13, 13, 13, 0.9)',
                            padding: 14,
                            titleFont: { family: 'Inter', size: 14, weight: '600' },
                            bodyFont: { family: 'Inter', size: 13 },
                            cornerRadius: 8,
                            boxPadding: 6,
                            yAlign: 'bottom'
                        }
                    },
                    scales: {
                        x: {
                            grid: { display: false, drawBorder: false },
                            ticks: { 
                                font: { family: 'Inter', size: 12 },
                                color: 'var(--neutral-500)',
                                padding: 10
                            }
                        },
                        y: {
                            type: 'linear',
                            display: true,
                            position: 'left',
                            grid: {
                                color: 'rgba(0,0,0,0.04)',
                                drawBorder: false
                            },
                            ticks: {
                                font: { family: 'Inter', size: 12 },
                                color: 'var(--neutral-500)',
                                padding: 15,
                                callback: function(value) {
                                    if(value >= 1000) return '₹' + (value/1000) + 'k';
                                    return '₹' + value;
                                }
                            }
                        },
                        y1: {
                            type: 'linear',
                            display: true,
                            position: 'right',
                            grid: { drawOnChartArea: false },
                            ticks: { 
                                font: { family: 'Inter', size: 12 },
                                color: 'var(--neutral-500)',
                                padding: 15 
                            }
                        }
                    }
                }
            });
        }
    });
</script>