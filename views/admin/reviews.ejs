<% layout("/layouts/boilerplate") %>

    <div class="container py-4 reveal reveal-up">
        <div class="flex-between mb-6">
            <div>
                <h2 class="mb-2">Manage Reviews</h2>
                <p class="text-muted">Monitor and moderate property reviews</p>
            </div>
            <a href="/admin" class="btn-modern btn-ghost">
                <i class="fas fa-arrow-left me-2"></i> Back to Dashboard
            </a>
        </div>

        <div class="card-modern overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead style="background-color: var(--neutral-100);">
                        <tr>
                            <th class="p-4 border-0 font-semibold text-muted">Author</th>
                            <th class="p-4 border-0 font-semibold text-muted">Rating</th>
                            <th class="p-4 border-0 font-semibold text-muted">Comment</th>
                            <th class="p-4 border-0 font-semibold text-muted">Sentiment</th>
                            <th class="p-4 border-0 font-semibold text-muted text-end">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% for(let review of reviews) { %>
                            <tr class="align-middle">
                                <td class="p-4 border-bottom" style="border-color: var(--neutral-200);">
                                    <div class="flex-center" style="justify-content: flex-start;">
                                        <div class="rounded-circle flex-center me-2 shadow-sm"
                                            style="width: 32px; height: 32px; font-size: 0.8rem; background: var(--gradient-secondary); color: white; font-weight: 700;">
                                            <%= review.author ? review.author.username[0].toUpperCase() : '?' %>
                                        </div>
                                        <span>
                                            <%= review.author ? review.author.username : 'Anonymous' %>
                                        </span>
                                    </div>
                                </td>
                                <td class="p-4 border-bottom" style="border-color: var(--neutral-200);">
                                    <div class="d-flex align-items-center gap-1">
                                        <span class="font-bold"><%= review.rating %></span>
                                        <i class="fas fa-star text-warning-500 text-xs"></i>
                                    </div>
                                </td>
                                <td class="p-4 border-bottom" style="border-color: var(--neutral-200);">
                                    <p class="mb-0 text-muted text-sm text-truncate" style="max-width: 300px;">
                                        <%= review.comment %>
                                    </p>
                                </td>
                                <td class="p-4 border-bottom" style="border-color: var(--neutral-200);">
                                    <% if(review.sentiment === 'positive') { %>
                                        <span class="badge badge-success">
                                            <i class="fas fa-face-smile me-1"></i> Positive
                                        </span>
                                    <% } else if(review.sentiment === 'negative') { %>
                                        <span class="badge" style="background: var(--error-light); color: var(--error-500);">
                                            <i class="fas fa-face-frown me-1"></i> Negative
                                        </span>
                                    <% } else { %>
                                        <span class="badge badge-primary">
                                            <i class="fas fa-face-meh me-1"></i> Neutral
                                        </span>
                                    <% } %>
                                </td>
                                <td class="p-4 border-bottom text-end" style="border-color: var(--neutral-200);">
                                    <form action="/admin/reviews/<%= review._id %>/delete" method="POST"
                                        class="d-inline"
                                        onsubmit="return confirm('Are you sure you want to delete this review?');">
                                        <button class="btn-modern btn-sm"
                                            style="color: var(--error-500); background: rgba(193, 53, 21, 0.1);">
                                            <i class="fas fa-trash-alt"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        <% } %>
                        <% if(reviews.length === 0) { %>
                            <tr>
                                <td colspan="5" class="p-10 text-center text-muted">
                                    <i class="fas fa-star text-neutral-300 mb-2" style="font-size: 2rem;"></i>
                                    <p>No reviews found to moderate.</p>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
