<% layout("/layouts/boilerplate") %>

    <div class="container py-4 animate-fade-in">
        <div class="flex-between mb-6">
            <div>
                <h2 class="mb-2">Manage Users</h2>
                <p class="text-muted">View and manage registered users</p>
            </div>
            <a href="/admin" class="btn-modern btn-ghost">
                <i class="fas fa-arrow-left me-2"></i> Back to Dashboard
            </a>
        </div>

        <div class="card-modern overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead style="background-color: var(--neutral-100);">
                        <tr>
                            <th class="p-4 border-0 font-semibold text-muted">User Info</th>
                            <th class="p-4 border-0 font-semibold text-muted">Role</th>
                            <th class="p-4 border-0 font-semibold text-muted text-end">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% for(let user of users) { %>
                            <tr class="align-middle">
                                <td class="p-4 border-bottom" style="border-color: var(--neutral-200);">
                                    <div class="flex-center" style="justify-content: flex-start;">
                                        <div class="rounded-circle bg-primary text-white flex-center me-3"
                                            style="width: 40px; height: 40px; font-weight: bold;">
                                            <%= user.username[0].toUpperCase() %>
                                        </div>
                                        <div>
                                            <h6 class="mb-0">
                                                <%= user.username %>
                                            </h6>
                                            <small class="text-muted">
                                                <%= user.email %>
                                            </small>
                                        </div>
                                    </div>
                                </td>
                                <td class="p-4 border-bottom" style="border-color: var(--neutral-200);">
                                    <% if(user.role==='admin' ) { %>
                                        <span class="badge badge-primary">
                                            <i class="fas fa-shield-alt me-1"></i> Admin
                                        </span>
                                        <% } else { %>
                                            <span class="badge"
                                                style="background: var(--neutral-200); color: var(--neutral-700);">
                                                <i class="fas fa-user me-1"></i> User
                                            </span>
                                            <% } %>
                                </td>
                                <td class="p-4 border-bottom text-end" style="border-color: var(--neutral-200);">
                                    <form action="/admin/users/<%= user._id %>/delete" method="POST" class="d-inline"
                                        onsubmit="return confirm('Are you sure you want to delete this user?');">
                                        <button class="btn-modern btn-sm"
                                            style="color: var(--error-500); background: rgba(193, 53, 21, 0.1);">
                                            <i class="fas fa-trash-alt"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                            <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>