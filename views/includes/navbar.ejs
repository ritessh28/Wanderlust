            aria-label="Search">
          <button class="search-btn-modern" type="submit">
            <i class="fa-solid fa-magnifying-glass"></i>
            <span>Search</span>
          </button>
        </form>
      </div>

      <!-- Right Side Navigation -->
      <div class="ms-auto d-flex align-items-center gap-3">
