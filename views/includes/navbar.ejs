          </a>
        <% } %>

        <!-- Dark Mode Toggle (Always Visible) -->
        <button id="themeToggle" class="btn-modern btn-ghost p-2" style="border-radius: 50%; width: 40px; height: 40px;">
          <i class="fa-solid fa-moon"></i>
        </button>

        <% if (!curruser) { %>
          <div class="auth-buttons">
            <a href="/login" class="btn-login">Log in</a>
            <a href="/signup" class="btn-signup">Sign up</a>
          </div>
          <% } else { %>
            <div class="d-flex align-items-center gap-3">
              <!-- Wishlist Link -->
              <a href="/wishlist" class="nav-link-modern">
                <i class="fa-solid fa-heart me-1"></i>
                Wishlist
              </a>

              <!-- User Menu Dropdown -->
              <div class="dropdown">
                <button class="user-menu-btn" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                  <i class="fa-solid fa-bars"></i>
                  <div class="user-avatar text-white">
                    <%= curruser.username.charAt(0).toUpperCase() %>
                  </div>
                </button>
                <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 mt-2" style="min-width: 250px;">
                  <li class="px-3 py-2 border-bottom">
                    <div class="fw-bold text-primary">
                      <%= curruser.username %>
                    </div>
                    <small class="text-muted">
                      <%= curruser.email %>
                    </small>
                  </li>
                  <li><a class="dropdown-item py-2" href="/profile"><i class="fa-solid fa-user me-2"></i>Profile</a>
                  </li>
                  <li><a class="dropdown-item py-2" href="/wishlist"><i class="fa-solid fa-heart me-2"></i>Wishlist</a>
                  </li>
                  <li><a class="dropdown-item py-2" href="/bookings"><i
                        class="fa-solid fa-suitcase me-2"></i>My Trips</a></li>
                  <li><a class="dropdown-item py-2" href="/host/bookings"><i
                        class="fa-solid fa-calendar-check me-2"></i>Bookings</a></li>
                  <li><a class="dropdown-item py-2 fw-semibold" href="/host/dashboard"><i
                        class="fa-solid fa-house-user me-2 text-primary"></i>Host Dashboard</a></li>
                  <% if (curruser.role && curruser.role.toString().toLowerCase() === 'admin') { %>
                  <li>
                    <hr class="dropdown-divider">
                  </li>
                  <li class="px-3 py-1"><span class="badge bg-primary-subtle text-primary border border-primary-subtle">Admin Access Active</span></li>
                  <li><a class="dropdown-item py-2 text-primary fw-bold" href="/admin/monitor"><i class="fa-solid fa-gauge-high me-2"></i>Monitor Platform</a></li>
                  <li><a class="dropdown-item py-2 text-primary fw-bold" href="/admin"><i class="fa-solid fa-shield-halved me-2"></i>Admin Dashboard</a></li>
                  <% } %>
                  <li>
                    <hr class="dropdown-divider">
                  </li>
                  <li><a class="dropdown-item py-2 text-danger fw-semibold" href="/logout"><i
                        class="fa-solid fa-right-from-bracket me-2"></i>Logout</a></li>
                </ul>
              </div>
            </div>
            <% } %>
      </div>

      <!-- Mobile Menu Items -->
      <div class="d-md-none mt-3">
        <!-- Search Bar (Mobile) -->
        <div class="navbar-search-modern">
          <form role="search" action="/listings/search" method="GET">
            <i class="fa-solid fa-magnifying-glass search-icon"></i>
            <input class="search-input-modern" type="search" name="q" placeholder="Search destinations..."
              aria-label="Search destinations">
            <button class="search-btn-modern" type="submit">
              <i class="fa-solid fa-magnifying-glass"></i>
            </button>
          </form>
        </div>

        <!-- Mobile Navigation Links -->
        <a class="nav-link-modern d-block mt-2" href="/listings">
          <i class="fa-solid fa-compass me-2"></i>
          Explore
        </a>
        <a class="nav-link-modern d-block" href="/listings/new">
          <i class="fa-solid fa-house-circle-check me-2"></i>
          Wanderlust your home
        </a>
        <% if (curruser) { %>
          <a class="nav-link-modern d-block" href="/wishlist">
            <i class="fa-solid fa-heart me-2"></i>
            Wishlist
          </a>
          <a class="nav-link-modern d-block" href="/bookings">
            <i class="fa-solid fa-suitcase me-2"></i>
            My Trips
          </a>
          <a class="nav-link-modern d-block" href="/host/bookings">
            <i class="fa-solid fa-calendar-check me-2"></i>
            Host Bookings
          </a>
          <a class="nav-link-modern d-block fw-semibold" href="/host/dashboard">
            <i class="fa-solid fa-house-user me-2 text-primary"></i>
            Host Dashboard
          </a>
          <a class="nav-link-modern d-block" href="/profile">
            <i class="fa-solid fa-user me-2"></i>
            Profile
          </a>
          <% if (curruser.role === 'admin') { %>
          <a class="nav-link-modern d-block text-primary fw-bold" href="/admin/monitor">
            <i class="fa-solid fa-gauge-high me-2"></i>
            Monitor Platform
          </a>
          <a class="nav-link-modern d-block text-primary" href="/admin">
            <i class="fa-solid fa-shield-halved me-2"></i>
            Admin Dashboard
          </a>
          <% } %>
          <a class="nav-link-modern d-block text-danger" href="/logout">
            <i class="fa-solid fa-right-from-bracket me-2"></i>
            Logout
          </a>
          <% } else { %>
            <div class="mt-3 d-flex flex-column gap-2">
              <a href="/login" class="btn-login text-center border">Log in</a>
              <a href="/signup" class="btn-signup text-center">Sign up</a>
            </div>
            <% } %>
      </div>
    </div>
  </div>
</nav>

<script>
  // Add scroll effect to navbar
  window.addEventListener('scroll', function () {
    const navbar = document.querySelector('.navbar-modern');
    if (window.scrollY > 50) {
      navbar.classList.add('scrolled');
    } else {
      navbar.classList.remove('scrolled');
    }
  });
</script>