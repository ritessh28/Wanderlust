<% layout("/layouts/boilerplate") %>

    <div class="container py-4 animate-fade-in">
        <div class="flex-between mb-6">
            <div>
                <h2 class="mb-2">My Wishlist</h2>
                <p class="text-muted">Your saved favorite places</p>
            </div>
            <a href="/listings" class="btn-modern btn-ghost">
                <i class="fas fa-arrow-left me-2"></i> Back to Listings
            </a>
        </div>

        <% if(listings && listings.length> 0) { %>
            <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
                <% for(let listing of listings) { %>
                    <div class="card-modern col listing-card mb-4 hover-lift">
                        <a href="/listings/<%= listing._id %>" class="list-link">
                            <div class="card-img-top-wrapper"
                                style="position: relative; overflow: hidden; border-radius: var(--radius-lg);">
                                <img src="<%= listing.images && listing.images.length > 0 ? listing.images[0].url : (listing.image && listing.image.url ? listing.image.url : '') %>" class="card-img-top" alt="listing_image"
                                    style="height: 20rem; object-fit: cover;">
                                <div class="card-img-overlay"></div>
                            </div>
                            <div class="card-body mt-2">
                                <p class="card-text">
                                    <b>
                                        <%= listing.title %>
                                    </b> <br>
                                    <span class="text-muted">
                                        <%= listing.location %>, <%= listing.country %>
                                    </span> <br>
                                    <span class="text-primary font-semibold">&#8377; <%=
                                            listing.price.toLocaleString("en-IN") %> / night</span>
                                </p>
                            </div>
                        </a>
                        <div class="px-3 pb-3">
                            <form action="/wishlist/<%= listing._id %>/remove" method="POST" class="d-grid">
                                <button class="btn-modern btn-sm"
                                    style="color: var(--error-500); background: rgba(193, 53, 21, 0.1); width: 100%;">
                                    <i class="fas fa-heart-broken me-2"></i> Remove from Wishlist
                                </button>
                            </form>
                        </div>
                    </div>
                    <% } %>
            </div>
            <% } else { %>
                <div class="text-center py-5">
                    <div class="mb-4">
                        <i class="far fa-heart text-muted" style="font-size: 4rem;"></i>
                    </div>
                    <h3>Your wishlist is empty</h3>
                    <p class="text-muted mb-4">Save places you'd like to visit to keep track of them here.</p>
                    <a href="/listings" class="btn-modern btn-primary">Explore Listings</a>
                </div>
                <% } %>
    </div>